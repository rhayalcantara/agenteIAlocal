# ============================================
# Configuración del Agente de IA
# ============================================

# ------------------------------------------
# Opción 1: Usar LM Studio (Modelo Local)
# ------------------------------------------
# Descomenta estas líneas para usar un modelo local con LM Studio
# LM Studio debe estar corriendo y sirviendo en la IP/puerto especificados

API_BASE_URL=http://192.168.1.96:1234/v1
MODEL_NAME=qwen/qwen3-30b-a3b-2507
OPENAI_API_KEY=not-needed

# ------------------------------------------
# Opción 2: Usar OpenAI API (Modelo en la Nube)
# ------------------------------------------
# Descomenta estas líneas y comenta las de arriba para usar OpenAI
# Requiere una API key válida de OpenAI

# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4
# OPENAI_API_KEY=sk-tu-clave-api-aqui

# ------------------------------------------
# Notas de Configuración
# ------------------------------------------

# API_BASE_URL: URL base del servidor de IA
#   - Para LM Studio local: http://localhost:1234/v1
#   - Para LM Studio en red: http://[IP]:1234/v1 (ejemplo: http://192.168.1.100:1234/v1)
#   - Para OpenAI: https://api.openai.com/v1

# MODEL_NAME: Nombre del modelo a usar
#   - Para LM Studio: el nombre del modelo cargado en LM Studio
#   - Para OpenAI: gpt-4, gpt-3.5-turbo, etc.

# OPENAI_API_KEY: Clave de API
#   - Para LM Studio: puede ser cualquier valor (no se valida)
#   - Para OpenAI: debe ser una clave válida que comience con 'sk-'
