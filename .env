# ============================================
# Configuracion del Agente de IA
# Sistema Multi-Proveedor
# ============================================

# ------------------------------------------
# Proveedor por defecto
# ------------------------------------------
# Opciones: openrouter, lmstudio, openai, claude, gemini
# Cambia este valor para alternar entre proveedores
# sin tener que comentar/descomentar lineas
PROVIDER_DEFAULT=lmstudio

# ------------------------------------------
# OpenRouter (Modelos en la Nube via OpenRouter)
# ------------------------------------------
# OpenRouter permite acceder a multiples modelos de IA
# desde un solo endpoint. Ver modelos: https://openrouter.ai/models
# Modelos con function calling: anthropic/claude-3.5-sonnet, google/gemini-pro-1.5
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------
# LM Studio (Modelo Local)
# ------------------------------------------
# LM Studio debe estar corriendo y sirviendo en la IP/puerto especificados
# La API key puede ser cualquier valor (no se valida en modelos locales)/
# No todos los modelos locales soportan function calling
# Modelos recomendados: Mistral 7B Instruct, Llama 3.1, Qwen 2.5
LMSTUDIO_BASE_URL=https://rhayalcantara-002-site2.ntempurl.com/api/v1
LMSTUDIO_MODEL=google/gemma-4-26b-a4b
#qwen/qwen3-30b-a3b-2507
#qwen/qwen3-30b-a3b-2507
#qwen3.5-27b
#zai-org/glm-4.7-flash 
#qwen/qwen3-vl-8b
#zai-org/glm-4.6v-flash # qwen/qwen3-30b-a3b-2507 #
LMSTUDIO_API_KEY=llm-gateway-key-2026-secure
# /subagente crea un plan para usar la habilidad agent_browser y entrar en google.com y buscar implementacion de agente ia con python,la guia esta en este archivo '/Users/rhayalcantara/proyectosia/agenteIAlocal/skills/agent-browser/README.md' con una lista de tareas y guardalo en un archivo con formato md
# ------------------------------------------
# OpenAI (Modelos en la Nube via OpenAI directamente)
# ------------------------------------------
# Requiere una API key valida de OpenAI (comienza con 'sk-')
# Descomenta estas lineas y coloca tu clave para usar OpenAI
#OPENAI_BASE_URL=https://api.openai.com/v1
#OPENAI_MODEL=gpt-4
#OPENAI_API_KEY=sk-tu-clave-api-aqui

# ------------------------------------------
# Claude (Plan Max - sin API key)
# ------------------------------------------
# Autenticación automática via claude-code-sdk
# No requiere API key ni base_url
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (SDK nativo google-genai) ---
# No requiere BASE_URL real, el SDK conecta directo a Google
# Modelos recomendados: gemini-2.0-flash, gemini-2.0-pro, gemini-2.5-flash
GEMINI_BASE_URL=gemini-sdk
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_API_KEY=AIzaSyCQGtQZFoRpxWEto8yDQJ4jL86rwtkBllo


# --- Gemini CLI (subprocess local) ---
# Invoca el binario `gemini` directamente via subprocess
# Modelos: gemini-2.5-flash, gemini-2.5-pro, etc.
GEMINI_CLI_MODEL=gemini-2.5-flash

# ------------------------------------------
# LLM Gateway (OpenRouter propio)
# ------------------------------------------
# Gateway distribuido para enrutar inferencia a workers remotos
# Workers con LM Studio se conectan por WebSocket al gateway
GATEWAY_BASE_URL=https://rhayalcantara-002-site2.ntempurl.com/v1
GATEWAY_API_KEY=llm-gateway-key-2026-secure

# ------------------------------------------
# Notas Importantes
# ------------------------------------------
# IMPORTANTE: No todos los modelos soportan function calling (herramientas)
# Para usar este agente, necesitas un modelo compatible con function calling
#
# Para agregar un nuevo proveedor:
#   1. Agrega su seccion con las variables BASE_URL, MODEL y API_KEY
#   2. Agrega el nombre del proveedor como opcion en PROVIDER_DEFAULT
#   3. Actualiza main.py para leer las variables del nuevo proveedor

# ------------------------------------------
# Configuracion de WhatsApp API (CloneWhatsApp)
# ------------------------------------------
# URL del backend de CloneWhatsApp
WHATSAPP_API_URL=https://rhayalcantara-002-site2.ntempurl.com
# API Key para autenticacion del agente (configurada en appsettings.json del backend)
WHATSAPP_API_KEY=whatsapp-agent-key-2024-secure

# ------------------------------------------
# Agente WhatsApp (Sistema de Mensajeria Asincrona)
# ------------------------------------------
WA_AGENT_PHONE=
WA_AGENT_PASSWORD= #AgentIA2026!
WA_AGENT_ID=eac6515e-d740-446a-8fd5-38af5f3d4861
# Chat IDs a monitorear (separados por coma, usado cuando GET /api/chats falla)
WA_MONITOR_CHAT_IDS=   #fd252d07-da5f-49f7-832c-c80f8bc36dd0
ß
# Usuario de prueba (para enviar mensajes al agente)
WA_TEST_USER_NAME=Bernhard
WA_TEST_USER_PHONE=
WA_TEST_USER_PASSWORD= #333-4444 RhayAgent2024!

# ------------------------------------------
# TTS - Texto a Voz (MLX-Audio / Qwen3-TTS)
# ------------------------------------------
# Modelo TTS local via MLX-Audio (corre en Apple Silicon)
# Voces disponibles: Ryan, Vivian, Serena, Aiden, etc.
TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-bf16
TTS_SPEAKER=serena
TTS_SPEED=1.0

# ------------------------------------------
# Modo Voz (STT + TTS en el loop principal)
# ------------------------------------------
# VOZ_HABILITADO=true  arranca el agente ya con voz activa
# Se puede cambiar en runtime con: /voz on | /voz off
VOZ_HABILITADO=false
VOZ_SAMPLERATE=16000
VOZ_DURACION_MAX=12
VOZ_SILENCIO_TIMEOUT=1.5
VOZ_UMBRAL_SILENCIO=0.01


TELEGRAM_BOT_TOKEN=8623671195:AAHhlffQtcGaN2EdFCQv6LHoV71AVjAFb4g
TELEGRAM_CHAT_ID=5483766132
TELEGRAM_VOZ_RESPUESTA=true 
TELEGRAM_MAX_OUTPUT_TOKENS=32000
